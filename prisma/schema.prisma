generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QueueEntry {
  id           String   @id @default(cuid())
  queueDate    String
  sequence     Int
  ticketNumber String
  serviceTitle String
  badge        String
  name         String
  whatsapp     String
  ktp          String?
  customerId   String?
  address      String?
  detail       String
  createdAt    DateTime @default(now())

  @@unique([queueDate, sequence])
  @@index([queueDate, createdAt])
  @@index([createdAt])
}

model DailyQueueCounter {
  queueDate    String   @id
  lastSequence Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model Feedback {
  id           String   @id @default(cuid())
  rating       Int
  message      String?
  ticketNumber String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model TutorialImage {
  id           String   @id @default(cuid())
  serviceIndex Int
  stepNumber   Int
  imagePath    String
  fileName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([serviceIndex, stepNumber])
}