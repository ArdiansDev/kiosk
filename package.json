{
  "name": "kiosk",
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "node scripts/web-dev.cjs",
    "dev:web": "node scripts/web-dev.cjs",
    "dev:electron": "node scripts/electron-open.cjs",
    "dev:all": "node scripts/electron-dev.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "node scripts/electron-dev.cjs",
    "electron:build": "npm run build && node scripts/prepare-electron-build.cjs && electron-builder",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "electron-serve": "^3.0.1",
    "next": "16.2.4",
    "pdf-to-printer": "^5.8.0",
    "prisma": "^6.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-simple-keyboard": "^3.8.221"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.pln.kiosk",
    "productName": "PLN Kiosk",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "prisma/prisma/dev.db",
        "to": "seed/dev.db"
      },
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "standalone/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      }
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "PLN-Kiosk-Portable-${version}.exe"
    }
  }
}
